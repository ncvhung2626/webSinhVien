{
  "name": "qlsv-mvc-unified",
  "version": "1.0.0",
  "description": "Hệ thống Quản lý Sinh viên - NestJS MVC",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc && node scripts/copy-assets.js",
    "start": "node dist/main",
    "start:dev": "nodemon --watch src --ext ts --exec \"npm run build && node dist/main\"",
    "start:debug": "nest start --debug --watch"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "emailjs": "^5.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.0",
    "qrcode": "^1.5.4",
    "qs": "^6.15.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "serverless-http": "^4.0.0",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.0",
