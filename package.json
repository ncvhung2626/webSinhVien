    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/qs": "^6.15.0",
    "@types/uuid": "^9.0.7",
    "@vercel/node": "^5.7.5",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "typescript": "^5.1.0"
  }
}
